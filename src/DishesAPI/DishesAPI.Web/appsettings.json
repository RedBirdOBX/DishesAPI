{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DishesDBConnectionString": "Data Source=Dishes.db"
  },
  "Authentication": {
    "DefaultScheme": "Bearer",
    "Schemes": {
      "Bearer": {
        "ValidAudiences": [ "MenuAPI" ]
      },
      "ValidIssuers": [ "dotnet-user-jwts" ]
    }
  }
}
